<?xml version="1.0" encoding="UTF-8"?>

<project name="APP1-release"
         default="release"
         basedir=".">

    <!-- WebPerformerで生成されたWebアプリのルート -->
    <property name="generated.app"
              location="../WPProject/generated/APP1"/>

    <!-- 実行する外部BATファイル -->
    <property name="external.batch"
              location="C:/deploy-tools/apply-external-batch.bat"/>

    <!-- 外部BATファイルの作業ディレクトリ -->
    <property name="external.batch.dir"
              location="C:/deploy-tools"/>

    <!-- WARファイルの出力先 -->
    <property name="release.dir"
              location="release"/>

    <!-- WARファイル名 -->
    <property name="war.name"
              value="APP1.war"/>

    <!-- 必要なファイルやディレクトリの存在確認 -->
    <target name="validate">

        <available file="${generated.app}/WEB-INF"
                   type="dir"
                   property="generated.app.exists"/>

        <fail unless="generated.app.exists"
              message="WebPerformer生成物が見つかりません: ${generated.app}/WEB-INF"/>

        <available file="${external.batch}"
                   type="file"
                   property="external.batch.exists"/>

        <fail unless="external.batch.exists"
              message="外部BATファイルが見つかりません: ${external.batch}"/>

    </target>

    <!-- 前回作成したreleaseディレクトリを削除 -->
    <target name="clean">

        <delete dir="${release.dir}"/>
        <mkdir dir="${release.dir}"/>

    </target>

    <!-- プロジェクト外にあるBATファイルを実行 -->
    <target name="execute-external-batch"
            depends="validate">

        <echo message="外部BATファイルを実行します: ${external.batch}"/>

        <exec executable="cmd.exe"
              dir="${external.batch.dir}"
              failonerror="true"
              failifexecutionfails="true">

            <arg value="/c"/>
            <arg path="${external.batch}"/>

        </exec>

        <echo message="外部BATファイルの実行が完了しました。"/>

    </target>

    <!-- WARファイルを作成 -->
    <target name="create-war"
            depends="clean,execute-external-batch">

        <war destfile="${release.dir}/${war.name}"
             basedir="${generated.app}"
             webxml="${generated.app}/WEB-INF/web.xml"/>

    </target>

    <!-- リリース処理 -->
    <target name="release"
            depends="create-war">

        <echo message="WARファイルを作成しました。"/>
        <echo message="${release.dir}/${war.name}"/>

    </target>

</project>